#billing logic
def calculate_slab_bill(consumption, slabs):
    bill = 0
    previous = 0

    for slab in slabs:
        limit = slab["limit"]
        rate = slab["rate"]

        if limit == -1:
            bill += (consumption - previous) * rate
            break

        if consumption > limit:
            bill += (limit - previous) * rate
            previous = limit
        else:
            bill += (consumption - previous) * rate
            break

    return bill
